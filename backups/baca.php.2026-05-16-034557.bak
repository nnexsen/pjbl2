<?php 
require 'koneksi.php';
session_start();

$profil = mysqli_fetch_assoc(mysqli_query($conn, "SELECT * FROM profil WHERE id = 1"));
$id = isset($_GET['id']) ? (int)$_GET['id'] : 0;

$stmt = mysqli_prepare($conn, "SELECT * FROM berita WHERE id = ?");
mysqli_stmt_bind_param($stmt, "i", $id);
mysqli_stmt_execute($stmt);
$berita = mysqli_fetch_assoc(mysqli_stmt_get_result($stmt));

if (!$berita) {
    header("Location: seluruh_berita.php");
    exit;
}
?>

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UACompatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><?= htmlspecialchars($berita['judul'], ENT_QUOTES, 'UTF-8'); ?> - <?= htmlspecialchars($profil['nama_sekolah'], ENT_QUOTES, 'UTF-8'); ?></title>
    <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>
    <?php require 'navbar.php'; ?>

    <div class="banner">
        <h2>📄 Detail Berita</h2>
    </div>

    <main>
        <a href="seluruh_berita.php" class="back-nav">← Kembali ke Daftar Berita</a>

        <article class="article">
            <h1><?= htmlspecialchars($berita['judul'], ENT_QUOTES, 'UTF-8'); ?></h1>
            
            <?php if ($berita['gambar']): ?>
                <img src="assets/uploads/<?= htmlspecialchars($berita['gambar'], ENT_QUOTES, 'UTF-8'); ?>" alt="Gambar Berita" class="img-detail">
            <?php endif; ?>
            
            <div style="color: var(--text-light); font-size: 0.9rem; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid var(--border-light);">
                <strong>Dipublikasikan:</strong> <?= date('d M Y', strtotime($berita['tanggal_posting'] ?? 'now')); ?>
            </div>

            <div style="line-height: 1.8; color: var(--text-dark); font-size: 1.05rem;">
                <?= nl2br(htmlspecialchars($berita['isi'], ENT_QUOTES, 'UTF-8')); ?>
            </div>

            <div style="margin-top: 2rem; padding-top: 2rem; border-top: 2px solid var(--border-light); text-align: center;">
                <a href="seluruh_berita.php" class="btn btn-secondary">Kembali ke Berita</a>
            </div>
        </article>

        <!-- Berita Terbaru Lainnya -->
        <section style="margin-top: 3rem;">
            <h3 style="color: var(--primary-color); font-size: 1.5rem; margin-bottom: 1.5rem;">📰 Berita Terkait</h3>
            <div class="berita-grid" style="grid-template-columns: repeat(3, 1fr);">
                <?php 
                $related = mysqli_query($conn, "SELECT * FROM berita WHERE id != $id ORDER BY id DESC LIMIT 3");
                while ($r = mysqli_fetch_assoc($related)): 
                ?>
                <div class="card-berita">
                    <?php if ($r['gambar']): ?>
                        <img src="assets/uploads/<?= htmlspecialchars($r['gambar'], ENT_QUOTES, 'UTF-8'); ?>" alt="Gambar Berita">
                    <?php else: ?>
                        <div style="width: 100%; height: 200px; background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-dark) 100%); display: flex; align-items: center; justify-content: center; color: white; font-size: 2.5rem;">📰</div>
                    <?php endif; ?>
                    <div class="card-berita-content">
                        <h4><?= htmlspecialchars($r['judul'], ENT_QUOTES, 'UTF-8'); ?></h4>
                        <p><?= htmlspecialchars(substr(strip_tags($r['isi']), 0, 100), ENT_QUOTES, 'UTF-8'); ?>...</p>
                        <a href="baca.php?id=<?= $r['id']; ?>" class="btn">Baca →</a>
                    </div>
                </div>
                <?php endwhile; ?>
            </div>
        </section>
    </main>

    <footer>
        <p>&copy; <?= date('Y') ?> <?= htmlspecialchars($profil['nama_sekolah'], ENT_QUOTES, 'UTF-8'); ?>. Semua hak dilindungi.</p>
    </footer>

</body>
</html>