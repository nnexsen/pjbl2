<?php
session_start();
require 'koneksi.php';


$query = mysqli_query($conn, "SELECT * FROM galeri ORDER BY id DESC");

$profil = mysqli_fetch_assoc(
    mysqli_query($conn, "SELECT * FROM profil WHERE id = 1")
);
?>

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galeri - <?= htmlspecialchars($profil['nama_sekolah'], ENT_QUOTES, 'UTF-8'); ?></title>
    <link rel="stylesheet" href="assets/css/style.css">
</head>
<body>
    <?php require 'navbar.php'; ?>

    <!-- Banner -->
    <div class="banner">
        <h2> Galeri Sekolah</h2>
    </div>

    <main>
        <section class="galeri-section">
            <p style="color: var(--text-light); margin-bottom: 2rem;">Koleksi foto kegiatan, acara, dan fasilitas sekolah kami</p>
            
            <div class="galeri-grid" style="grid-template-columns: repeat(3, 1fr);">
                <?php 
                $count = 0;
                while($g = mysqli_fetch_assoc($query)): 
                    $count++;
                ?>
                <div class="card-galeri">
                    <img src="assets/uploads/galeri/<?= htmlspecialchars($g['gambar'], ENT_QUOTES, 'UTF-8'); ?>" alt="Galeri">
                    <div class="card-galeri-content">
                        <h3><?= htmlspecialchars($g['judul'], ENT_QUOTES, 'UTF-8'); ?></h3>
                        <p><?= htmlspecialchars($g['deskripsi'], ENT_QUOTES, 'UTF-8'); ?></p>
                    </div>
                </div>
                <?php endwhile; ?>
            </div>

            <?php if ($count == 0): ?>
            <div class="alert alert-info" style="text-align: center; margin-top: 2rem;">
                <p>Belum ada galeri yang dipublikasikan.</p>
            </div>
            <?php endif; ?>
        </section>
    </main>

    <footer>
        <p>&copy; <?= date('Y') ?> <?= htmlspecialchars($profil['nama_sekolah'], ENT_QUOTES, 'UTF-8'); ?>. Semua hak dilindungi.</p>
    </footer>

</body>
</html>